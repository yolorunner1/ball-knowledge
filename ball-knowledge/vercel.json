{
  "version": 2,
  "rewrites": [
    { "source": "/api/fixtures", "destination": "/api/fixtures.js" },
    { "source": "/api/standings", "destination": "/api/standings.js" },
    { "source": "/api/scorers", "destination": "/api/scorers.js" },
